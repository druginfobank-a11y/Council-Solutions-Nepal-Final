
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
    <title>Council Solutions Nepal</title>
    
    <!-- PWA Primary Metadata -->
    <meta name="theme-color" content="#020617">
    <meta name="description" content="Premium LMS for Nepalese council exam preparation.">
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/png" href="/logo-192.png">
    
    <!-- iOS / Safari Support -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="CSN Nepal">
    <link rel="apple-touch-icon" href="/logo-192.png">
    <script>
        const savedTheme = localStorage.getItem('csn_theme');
        if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <link rel="stylesheet" href="/index.css">
</head>
<body class="h-full antialiased selection:bg-blue-500/20">
    <div id="root"></div>
    <script type="module" src="/index.tsx"></script>
</body>
</html>
